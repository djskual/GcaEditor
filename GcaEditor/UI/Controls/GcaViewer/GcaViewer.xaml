<UserControl x:Class="GcaEditor.UI.Controls.GcaViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto" Width="Auto">
    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="Background" Value="#242B34"/>
            <Setter Property="BorderBrush" Value="#465468"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#2F3946"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Bd" Property="Background" Value="#3A4657"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="Bd" Property="Background" Value="#1C2128"/><Setter Property="Foreground" Value="#687587"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="Background" Value="#242B34"/>
            <Setter Property="BorderBrush" Value="#465468"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#2F3946"/></Trigger>
                            <Trigger Property="IsChecked" Value="True"><Setter TargetName="Bd" Property="Background" Value="#4F8CFF"/><Setter TargetName="Bd" Property="BorderBrush" Value="#6B9DFF"/><Setter Property="Foreground" Value="White"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border x:Name="RootBorder"
            Background="#13181D"
            BorderBrush="#2F3742"
            BorderThickness="1"
            CornerRadius="10"
            Padding="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer x:Name="EditorScroll"
                          Grid.Row="0"
                          Background="Black"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalContentAlignment="Left"
                          VerticalContentAlignment="Top"
                          PanningMode="Both"
                          IsManipulationEnabled="True"
                          SizeChanged="EditorScroll_SizeChanged">

                <Grid x:Name="ZoomRoot">
                    <Grid.LayoutTransform>
                        <ScaleTransform x:Name="ZoomScale"/>
                    </Grid.LayoutTransform>

                    <Image x:Name="BackgroundImage" Stretch="None"/>
                    <Canvas x:Name="AmbientLayer" Background="Transparent"/>
                    <Canvas x:Name="SunLayer" Background="Transparent"/>

                    <Border x:Name="MoveHitLayer"
                            Background="Transparent"
                            Visibility="Collapsed"/>

                    <Border x:Name="PlacementHitLayer"
                            Background="Transparent"
                            Visibility="Collapsed"/>
                </Grid>
            </ScrollViewer>

            <!-- Bottom bar -->
            <Border x:Name="BottomBar"
                    Grid.Row="1"
                    Margin="0,8,0,0"
                    Background="#141414"
                    CornerRadius="8"
                    Padding="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="SelectedZoneText"
                               Grid.Column="0"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0"
                               Text=""/>

                    <TextBlock x:Name="ZoomText"
                               Grid.Column="2"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               Text="Zoom: Fit"/>

                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                        <Button Content="Fit" Width="48" Height="24" Margin="0,0,6,0" Click="Fit_Click"/>
                        <Button Content="-"   Width="32" Height="24" Margin="0,0,6,0" Click="ZoomOut_Click"/>
                        <Button Content="+"   Width="32" Height="24" Click="ZoomIn_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Opacity bar -->
            <Border x:Name="OpacityBar"
                    Grid.Row="2"
                    Margin="0,6,0,0"
                    Background="#141414"
                    CornerRadius="8"
                    Padding="10,6"
                    SnapsToDevicePixels="True">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Bright icon, tinted white -->
                    <Border x:Name="OpacityIcon"
                            Grid.Column="0"
                            Width="18"
                            Height="18"
                            Background="White"
                            CornerRadius="2"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center">
                        <Border.OpacityMask>
                            <ImageBrush ImageSource="/Assets/bright.png" Stretch="Uniform"/>
                        </Border.OpacityMask>
                    </Border>

                    <!-- All Zones toggle -->
                    <ToggleButton x:Name="AllZonesButton"
                                  Grid.Column="1"
                                  Content="All Zones"
                                  MinWidth="90"
                                  Height="22"
                                  Margin="0,0,10,0"
                                  VerticalAlignment="Center"
                                  Padding="10,0"/>

                    <!-- Track + Thumb (Canvas) -->
                    <Border x:Name="OpacityTrackBorder"
                            Grid.Column="2"
                            Height="18"
                            CornerRadius="5"
                            Background="#0B0B0B"
                            BorderBrush="#2A2A2A"
                            BorderThickness="1"
                            VerticalAlignment="Center"
                            SnapsToDevicePixels="True"
                            ClipToBounds="True">
                        <Canvas x:Name="OpacityTrackCanvas"
                                Height="18"
                                Background="#00000000">
                            <Border x:Name="OpacityThumb"
                                    Width="32"
                                    Height="18"
                                    CornerRadius="5"
                                    Background="#B0B0B0"
                                    BorderBrush="#2A2A2A"
                                    BorderThickness="1"
                                    Canvas.Left="0"
                                    Canvas.Top="0"/>
                        </Canvas>
                    </Border>

                </Grid>
            </Border>

            <!-- Color bar -->
            <Border x:Name="ColorBar"
                    Grid.Row="3"
                    Margin="0,6,0,0"
                    Background="#141414"
                    CornerRadius="8"
                    Padding="10,6"
                    SnapsToDevicePixels="True">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Colors icon -->
                    <Image Source="/Assets/colors.png"
                           Width="18"
                           Height="18"
                           Margin="0,0,10,0"
                           VerticalAlignment="Center"/>
                    <UniformGrid x:Name="ColorSwatches"
                                 Grid.Column="1"
                                 Columns="30"
                                 Height="18"
                                 VerticalAlignment="Center">
                        <!-- 10 colors -->
                        <!--<Border Background="White"     Margin="1" CornerRadius="3" Tag="#FFFFFFFF" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown"/>
                        <Border Background="Red"       Margin="1" CornerRadius="3" Tag="#FFFF0000" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown"/>
                        <Border Background="#FFFF7A00" Margin="1" CornerRadius="3" Tag="#FFFF7A00" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown"/>
                        <Border Background="Yellow"    Margin="1" CornerRadius="3" Tag="#FFFFFF00" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown"/>
                        <Border Background="#FF00FF00" Margin="1" CornerRadius="3" Tag="#FF00FF00" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown"/>
                        <Border Background="#FF00FFB3" Margin="1" CornerRadius="3" Tag="#FF00FFB3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown"/>
                        <Border Background="#FF00B3FF" Margin="1" CornerRadius="3" Tag="#FF00B3FF" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown"/>
                        <Border Background="#FF0066FF" Margin="1" CornerRadius="3" Tag="#FF0066FF" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown"/>
                        <Border Background="#FF7A00FF" Margin="1" CornerRadius="3" Tag="#FF7A00FF" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown"/>
                        <Border Background="#FFFF00B3" Margin="1" CornerRadius="3" Tag="#FFFF00B3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown"/>
                        -->
                        <!-- 30 colors -->
                        <Border Background="#FFFFFFFF" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FFFFFFFF"/>
                        <Border Background="#FFFF0000" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FFFF0000"/>
                        <Border Background="#FFFF2000" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FFFF2000"/>
                        <Border Background="#FFFF4000" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FFFF4000"/>
                        <Border Background="#FFFF6000" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FFFF6000"/>
                        <Border Background="#FFFF8000" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FFFF8000"/>
                        <Border Background="#FFFFA000" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FFFFA000"/>
                        <Border Background="#FFFFC000" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FFFFC000"/>
                        <Border Background="#FFFFE000" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FFFFE000"/>
                        <Border Background="#FFFFFF00" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FFFFFF00"/>
                        <Border Background="#FFE0FF00" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FFE0FF00"/>
                        <Border Background="#FFC0FF00" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FFC0FF00"/>
                        <Border Background="#FFA0FF00" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FFA0FF00"/>
                        <Border Background="#FF80FF00" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FF80FF00"/>
                        <Border Background="#FF60FF00" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FF60FF00"/>
                        <Border Background="#FF00FF00" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FF00FF00"/>
                        <Border Background="#FF00FF40" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FF00FF40"/>
                        <Border Background="#FF00FF80" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FF00FF80"/>
                        <Border Background="#FF00FFC0" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FF00FFC0"/>
                        <Border Background="#FF00FFFF" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FF00FFFF"/>
                        <Border Background="#FF00C0FF" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FF00C0FF"/>
                        <Border Background="#FF0080FF" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FF0080FF"/>
                        <Border Background="#FF0000FF" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FF0000FF"/>
                        <Border Background="#FF2000FF" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FF2000FF"/>
                        <Border Background="#FF4000FF" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FF4000FF"/>
                        <Border Background="#FF6000FF" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FF6000FF"/>
                        <Border Background="#FF8000FF" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FF8000FF"/>
                        <Border Background="#FFAA00FF" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FFAA00FF"/>
                        <Border Background="#FFCC00FF" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FFCC00FF"/>
                        <Border Background="#FFFF00FF" Margin="1" CornerRadius="3" MouseLeftButtonDown="ColorSwatch_MouseLeftButtonDown" Tag="#FFFF00FF"/>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>