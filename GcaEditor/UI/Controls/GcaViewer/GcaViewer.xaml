<UserControl x:Class="GcaEditor.UI.Controls.GcaViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto" Width="Auto">
    <Border x:Name="RootBorder"
            BorderBrush="#2A2A2A"
            BorderThickness="1"
            CornerRadius="10"
            Padding="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer x:Name="EditorScroll"
                          Grid.Row="0"
                          Background="Black"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalContentAlignment="Left"
                          VerticalContentAlignment="Top"
                          PanningMode="Both"
                          IsManipulationEnabled="True"
                          SizeChanged="EditorScroll_SizeChanged">

                <Grid x:Name="ZoomRoot">
                    <Grid.LayoutTransform>
                        <ScaleTransform x:Name="ZoomScale"/>
                    </Grid.LayoutTransform>

                    <Image x:Name="BackgroundImage" Stretch="None"/>
                    <Canvas x:Name="AmbientLayer" Background="Transparent"/>
                    <Canvas x:Name="SunLayer" Background="Transparent"/>

                    <Border x:Name="MoveHitLayer"
                            Background="Transparent"
                            Visibility="Collapsed"/>

                    <Border x:Name="PlacementHitLayer"
                            Background="Transparent"
                            Visibility="Collapsed"/>
                </Grid>
            </ScrollViewer>

            <!-- Bottom bar -->
            <Border x:Name="BottomBar"
                    Grid.Row="1"
                    Margin="0,8,0,0"
                    Background="#141414"
                    CornerRadius="8"
                    Padding="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="SelectedZoneText"
                               Grid.Column="0"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0"
                               Text=""/>

                    <TextBlock x:Name="ZoomText"
                               Grid.Column="2"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               Text="Zoom: Fit"/>

                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                        <Button Content="Fit" Width="48" Height="24" Margin="0,0,6,0" Click="Fit_Click"/>
                        <Button Content="-"   Width="32" Height="24" Margin="0,0,6,0" Click="ZoomOut_Click"/>
                        <Button Content="+"   Width="32" Height="24" Click="ZoomIn_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Opacity bar -->
            <Border x:Name="OpacityBar"
                    Grid.Row="2"
                    Margin="0,6,0,0"
                    Background="#141414"
                    CornerRadius="8"
                    Padding="10,6"
                    SnapsToDevicePixels="True">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Bright icon, tinted white -->
                    <Border x:Name="OpacityIcon"
                            Grid.Column="0"
                            Width="18"
                            Height="18"
                            Background="White"
                            CornerRadius="2"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center">
                        <Border.OpacityMask>
                            <ImageBrush ImageSource="/Assets/bright.png" Stretch="Uniform"/>
                        </Border.OpacityMask>
                    </Border>

                    <!-- All Zones toggle -->
                    <ToggleButton x:Name="AllZonesButton"
                                  Grid.Column="1"
                                  Content="All Zones"
                                  MinWidth="90"
                                  Height="22"
                                  Margin="0,0,10,0"
                                  VerticalAlignment="Center"
                                  Padding="10,0"/>

                    <!-- Track + Thumb (Canvas) -->
                    <Border x:Name="OpacityTrackBorder"
                            Grid.Column="2"
                            Height="18"
                            CornerRadius="5"
                            Background="#0B0B0B"
                            BorderBrush="#2A2A2A"
                            BorderThickness="1"
                            VerticalAlignment="Center"
                            SnapsToDevicePixels="True"
                            ClipToBounds="True">
                        <Canvas x:Name="OpacityTrackCanvas"
                                Height="18"
                                Background="#00000000">
                            <Border x:Name="OpacityThumb"
                                    Width="32"
                                    Height="18"
                                    CornerRadius="5"
                                    Background="#B0B0B0"
                                    BorderBrush="#2A2A2A"
                                    BorderThickness="1"
                                    Canvas.Left="0"
                                    Canvas.Top="0"/>
                        </Canvas>
                    </Border>

                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>