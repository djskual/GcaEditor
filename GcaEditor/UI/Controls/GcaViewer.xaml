<UserControl x:Class="GcaEditor.UI.Controls.GcaViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto" Width="Auto">
    <Border x:Name="RootBorder"
            BorderBrush="#2A2A2A"
            BorderThickness="1"
            CornerRadius="10"
            Padding="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer x:Name="EditorScroll"
                          Grid.Row="0"
                          Background="Black"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalContentAlignment="Left"
                          VerticalContentAlignment="Top"
                          PanningMode="Both"
                          IsManipulationEnabled="True"
                          SizeChanged="EditorScroll_SizeChanged">

                <Grid x:Name="ZoomRoot">
                    <Grid.LayoutTransform>
                        <ScaleTransform x:Name="ZoomScale"/>
                    </Grid.LayoutTransform>

                    <!-- Background -->
                    <Image x:Name="BackgroundImage" Stretch="None"/>

                    <!-- Layers -->
                    <Canvas x:Name="AmbientLayer" Background="Transparent"/>
                    <Canvas x:Name="SunLayer" Background="Transparent"/>
                </Grid>
            </ScrollViewer>

            <Border x:Name="BottomBar"
                    Grid.Row="1"
                    Margin="0,8,0,0"
                    Background="#141414"
                    CornerRadius="8"
                    Padding="6">
                <DockPanel LastChildFill="False">
                    <TextBlock x:Name="ZoomText"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Text="Zoom: Fit" />

                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button Content="Fit" Width="48" Height="24" Margin="0,0,6,0" Click="Fit_Click"/>
                        <Button Content="-" Width="32" Height="24" Margin="0,0,6,0" Click="ZoomOut_Click"/>
                        <Button Content="+" Width="32" Height="24" Click="ZoomIn_Click"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
