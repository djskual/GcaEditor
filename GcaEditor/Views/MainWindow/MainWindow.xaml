<Window x:Class="GcaEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:GcaEditor.UI.Controls"
        Icon="/Assets/app.ico"
        Title="GCA Editor"
        Width="1400"
        Height="900"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}">

    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Undo" Executed="Undo_Executed" CanExecute="Undo_CanExecute"/>
        <CommandBinding Command="ApplicationCommands.Redo" Executed="Redo_Executed" CanExecute="Redo_CanExecute"/>
        <CommandBinding Command="ApplicationCommands.Save" Executed="Save_Executed" CanExecute="Save_CanExecute"/>
    </Window.CommandBindings>

    <Window.InputBindings>
        <KeyBinding Command="ApplicationCommands.Undo" Modifiers="Control" Key="Z"/>
        <KeyBinding Command="ApplicationCommands.Redo" Modifiers="Control" Key="Y"/>
        <KeyBinding Command="ApplicationCommands.Save" Modifiers="Control" Key="S"/>
    </Window.InputBindings>

    <Grid Background="{DynamicResource AppWindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Menu Grid.Row="0" Grid.ColumnSpan="2">
            <MenuItem Header="_File">
                <MenuItem Header="_Save .gca" Command="ApplicationCommands.Save" ToolTip="Ctrl+S" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Command="ApplicationCommands.Undo" ToolTip="Ctrl+Z" />
                <Separator/>
                <MenuItem Header="_Redo" Command="ApplicationCommands.Redo" ToolTip="Ctrl+Y" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="Check for updates" Click="CheckUpdate_Click"/>
                <Separator/>
                <MenuItem Header="_About" Click="About_Click"/>
            </MenuItem>
        </Menu>


        <!-- LEFT -->
        <Border Grid.Row="1" Grid.Column="0" Margin="10,10,0,10" Background="{DynamicResource AppPanelBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="14" Padding="12"><Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">

                <Button x:Name="ChooseCarButton"
                        Content="Choose car"
                        Click="ChooseCar_Click"
                        Margin="0,0,0,6"/>

                <TextBlock x:Name="CurrentCarLabel"
                           Text="Car: -"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           Margin="0,0,0,10"/>

                <StackPanel x:Name="MainControlsPanel">
                <Button x:Name="ImportBackgroundButton"
                        Content="Import Background (PNG 1280x556 or 800x417)"
                        Click="ImportBackground_Click"
                        Margin="0,0,0,6"/>

                <Button x:Name="OpenGcaButton"
                        Content="Open .gca"
                        Click="OpenGca_Click"
                        Margin="0,0,0,6"
                        IsEnabled="False"/>
                        <TextBlock x:Name="MibLabel"
                           Text="MIB: -"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           Margin="0,0,0,12"/>
                </StackPanel>
            </StackPanel>

            <StackPanel x:Name="MainLeftPanels" Grid.Row="2">

                <!-- ZONES -->
                <GroupBox Header="Zones" Padding="8" Height="215" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListBox x:Name="ZonesList"
                                 Height="92"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="ZonesList_SelectionChanged"/>

                        <Grid Grid.Row="2" Margin="0,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="2" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Available" FontSize="11" Foreground="{DynamicResource AppMutedTextBrush}" Margin="0,0,0,2"/>
                                    <ComboBox x:Name="AddZoneCombo"
                                              Height="28"
                                              VerticalContentAlignment="Center"
                                              Padding="6,2"
                                              IsEditable="False"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Custom" FontSize="11" Foreground="{DynamicResource AppMutedTextBrush}" Margin="0,0,0,2"/>
                                    <TextBox x:Name="CustomZoneIdBox"
                                             Width="70"
                                             Height="28"
                                             VerticalContentAlignment="Center"
                                             Padding="6,2"
                                             ToolTip="Custom Zone ID (0..65535)"/>
                                </StackPanel>

                                <Button Grid.Column="4" Content="Add" Height="28" Padding="10,4" VerticalAlignment="Bottom" Click="AddZone_Click"/>
                                <Button Grid.Column="6" Content="Delete" Height="28" Padding="10,4" VerticalAlignment="Bottom" Click="DeleteZone_Click"/>
                            </Grid>
                        </Grid>
                    </Grid>
                </GroupBox>

                <!-- AMBIENT IMAGES -->
                <GroupBox x:Name="AmbientGroup" Header="Ambient images" Padding="8" Height="360">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Drive side selection -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="Side:" Foreground="{DynamicResource AppMutedTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <RadioButton x:Name="SideLhd" Content="LHD" IsChecked="True" Margin="0,0,10,0" Checked="Side_Checked"/>
                            <RadioButton x:Name="SideRhd" Content="RHD" Checked="Side_Checked"/>
                        </StackPanel>

                        <!-- List of slots (with RGB selection checkbox) -->
                        <ListView x:Name="AmbientList"
                                  Grid.Row="2"
                                  Height="150"
                                  SelectionChanged="AmbientList_SelectionChanged"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="RGB" Width="40">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border HorizontalAlignment="Stretch"
                                                            VerticalAlignment="Stretch"
                                                            Padding="0">
                                                        <CheckBox IsChecked="{Binding RgbEnabled}"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Margin="-8,0,0,0"
                                                                  Padding="0"
                                                                  Checked="AmbientRgbCheckbox_Changed"
                                                                  Unchecked="AmbientRgbCheckbox_Changed"/>
                                                    </Border>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <GridViewColumn Header="Slot" Width="40">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Index, StringFormat={}{0:00}}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               TextAlignment="Center"
                                                               Margin="-10,0,0,0"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>

                                        <GridViewColumn Header="Status" Width="195">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Display}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                        </ListView>

                        <TextBlock x:Name="AmbientMoveHint"
                                   Grid.Row="4"
                                   Margin="0,2,0,0"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Move mode: drag the selected image. ESC to cancel."
                                   Visibility="Collapsed"/>

                        <TextBlock x:Name="AmbientPlacementHint"
                                   Grid.Row="4"
                                   Margin="0,2,0,0"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Placement mode: click in the viewer to place the selected ambient image (ESC to cancel)."
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>

                        <!-- Buttons: 3 lines -->
                        <StackPanel Grid.Row="8" Orientation="Vertical">

                            <!-- Line 1: import file / import folder / delete -->
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Import file..."
                                        Click="ImportAmbientFile_Click"
                                        Padding="10,4"
                                        MinWidth="80"
                                        Margin="0,0,6,0"/>

                                <Button Content="Import folder..."
                                        Click="ImportAmbientFolder_Click"
                                        Padding="10,4"
                                        MinWidth="80"
                                        Margin="0,0,6,0"/>

                                <Button Content="Delete"
                                        Click="ClearAmbient_Click"
                                        Padding="10,4"
                                        MinWidth="75"/>
                            </StackPanel>

                            <!-- Line 2: hide/show / place / cancel -->
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button x:Name="ToggleAmbientButton"
                                        Content="Hide/Show"
                                        Click="ToggleAmbientVisibility_Click"
                                        Padding="10,4"
                                        MinWidth="80"
                                        Margin="0,0,6,0"/>

                                <Button x:Name="PlaceAmbientButton"
                                        Content="Place"
                                        Click="PlaceAmbient_Click"
                                        Padding="10,4"
                                        MinWidth="90"
                                        Margin="0,0,6,0"/>

                                <Button x:Name="CancelPlaceAmbientButton"
                                        Content="Cancel"
                                        Click="CancelPlaceAmbient_Click"
                                        Padding="10,4"
                                        MinWidth="90"
                                        IsEnabled="False"/>
                            </StackPanel>

                            <!-- Line 3: Move Ambient / cancel -->
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button x:Name="MoveAmbientButton"
                                    Content="Move"
                                    Click="MoveAmbient_Click"
                                    Padding="10,4"
                                    MinWidth="132"
                                    Margin="0,0,8,0"/>

                                <Button x:Name="CancelMoveAmbientButton"
                                    Content="Cancel move"
                                    IsEnabled="False"
                                    Click="CancelMoveAmbient_Click"
                                    Padding="10,4"
                                    MinWidth="132"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </GroupBox>

            </StackPanel>
        </Grid></Border>

        <!-- RIGHT -->
        <Grid x:Name="ViewerHost" Grid.Row="1" Grid.Column="1" Margin="12" SizeChanged="ViewerHost_SizeChanged">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <controls:GcaViewer x:Name="Viewer"
                                Grid.Row="0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Width="980"
                                Height="402"/>
        </Grid>
    </Grid>
</Window>