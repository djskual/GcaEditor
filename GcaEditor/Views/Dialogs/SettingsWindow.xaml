<Window x:Class="GcaEditor.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="720"
        Height="430"
        MinWidth="720"
        MinHeight="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT NAV -->
            <Border Grid.Column="0"
                    Background="{DynamicResource AppPanelBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="8">
                <ListBox x:Name="SectionList"
                         SelectionChanged="SectionList_SelectionChanged"
                         BorderThickness="0"
                         Background="Transparent"
                         SelectedIndex="0">
                    <ListBoxItem x:Name="NavGeneral" Content="General"/>
                    <ListBoxItem x:Name="NavEditor" Content="Editor"/>
                    <ListBoxItem x:Name="NavViewer" Content="Viewer"/>
                    <ListBoxItem x:Name="NavUpdates" Content="Updates"/>
                </ListBox>
            </Border>

            <!-- RIGHT CONTENT -->
            <Border Grid.Column="2"
                    Background="{DynamicResource AppPanelBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14">
                <Grid>
                    <!-- GENERAL -->
                    <StackPanel x:Name="GeneralPanel">
                        <TextBlock Text="General"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <CheckBox x:Name="AutoCheckUpdatesCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Check for updates automatically at startup"/>

                        <CheckBox x:Name="RememberWindowPlacementCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Remember window size and position"
                                  Margin="0,10,0,0"/>

                        <CheckBox x:Name="ConfirmBeforeResetCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Confirm before resetting the current workspace"
                                  Margin="0,10,0,0"/>
                    </StackPanel>

                    <!-- EDITOR -->
                    <StackPanel x:Name="EditorPanel" Visibility="Collapsed">
                        <TextBlock Text="Editor"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Text="Maximum undo history"/>

                            <ComboBox x:Name="UndoHistoryCombo"
                                      Grid.Column="1"
                                      Width="110"
                                      HorizontalAlignment="Right"
                                      IsEditable="False"/>
                        </Grid>

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Undo history changes apply on the next app launch."/>
                    </StackPanel>

                    <!-- VIEWER -->
                    <StackPanel x:Name="ViewerPanel" Visibility="Collapsed">
                        <TextBlock Text="Viewer"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <CheckBox x:Name="InvertHorizontalScrollCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Invert horizontal trackpad scrolling"/>
                    </StackPanel>

                    <!-- UPDATES -->
                    <StackPanel x:Name="UpdatesPanel" Visibility="Collapsed">
                        <TextBlock Text="Updates"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <CheckBox x:Name="IncludePrereleaseCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Include prerelease versions in update checks"/>

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="When enabled, beta and prerelease versions are considered during update checks."/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Cancel"
                    Width="90"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>

            <Button Content="Save"
                    Width="90"
                    IsDefault="True"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
