<Window x:Class="GcaEditor.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="760"
        Height="460"
        MinWidth="760"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT NAV -->
            <Border Grid.Column="0"
                    Background="{DynamicResource AppPanelBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="8">
                <ListBox x:Name="SectionList"
                         SelectionChanged="SectionList_SelectionChanged"
                         BorderThickness="0"
                         Background="Transparent"
                         SelectedIndex="0">
                    <ListBoxItem Content="General"/>
                    <ListBoxItem Content="Editor"/>
                    <ListBoxItem Content="Viewer"/>
                    <ListBoxItem Content="Updates"/>
                </ListBox>
            </Border>

            <!-- RIGHT CONTENT -->
            <Border Grid.Column="2"
                    Background="{DynamicResource AppPanelBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16">
                <Grid x:Name="SectionHost" Opacity="1">
                    <!-- GENERAL -->
                    <StackPanel x:Name="GeneralPanel">
                        <TextBlock Text="General"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <CheckBox x:Name="RememberWindowPlacementCheck"
                                   Style="{StaticResource LabeledCheckBoxStyle}"
                                   Content="Remember window size and position"/>

                        <CheckBox x:Name="AutoLoadLastProjectCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Auto-load last project at startup"
                                  Margin="0,10,0,0"/>

                        <CheckBox x:Name="ConfirmBeforeResetCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Confirm before resetting the current workspace"
                                  Margin="0,10,0,0"/>

                        <CheckBox x:Name="ConfirmBeforeDeleteZoneCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Confirm before deleting a zone"
                                  Margin="0,10,0,0"/>

                        <CheckBox x:Name="ConfirmBeforeDeleteAmbientCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Confirm before deleting an ambient image"
                                  Margin="0,10,0,0"/>

                        <TextBlock Text="Default save folder"
                                   Margin="0,18,0,6"
                                   Foreground="{DynamicResource AppMutedTextBrush}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="DefaultSaveFolderTextBox"
                                     Grid.Column="0"
                                     Height="30"
                                     VerticalContentAlignment="Center"/>

                            <Button Grid.Column="2"
                                    Width="90"
                                    Height="30"
                                    Content="Browse..."
                                    Click="BrowseDefaultSaveFolder_Click"/>
                        </Grid>

                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="If empty, the Save GCA dialog opens in the currently loaded GCA folder."/>
                    </StackPanel>

                    <!-- EDITOR -->
                    <StackPanel x:Name="EditorPanel" Visibility="Collapsed">
                        <TextBlock Text="Editor"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="Maximum undo history"/>

                                <ComboBox x:Name="UndoHistoryCombo"
                                          Grid.Column="1"
                                          Width="110"
                                          HorizontalAlignment="Right"
                                          IsEditable="False"/>
                            </Grid>

                            <TextBlock Grid.Row="1"
                                       Margin="0,12,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="Undo history changes apply on the next app launch."/>
                        </Grid>
                    </StackPanel>

                    <!-- VIEWER -->
                    <StackPanel x:Name="ViewerPanel" Visibility="Collapsed">
                        <TextBlock Text="Viewer"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <CheckBox x:Name="InvertHorizontalScrollCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Invert horizontal trackpad scrolling"/>

                        <CheckBox x:Name="AutoFitViewerAfterBackgroundLoadCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Auto-fit viewer after loading a background"
                                  Margin="0,10,0,0"/>
                    </StackPanel>

                    <!-- UPDATES -->
                    <StackPanel x:Name="UpdatesPanel" Visibility="Collapsed">
                        <TextBlock Text="Updates"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <CheckBox x:Name="AutoCheckUpdatesCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Check for updates automatically at startup"/>

                        <CheckBox x:Name="IncludePrereleaseCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Include prerelease versions in update checks"
                                  Margin="0,10,0,0"/>

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="When enabled, beta and prerelease versions are considered during update checks."/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Cancel"
                    Width="90"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>

            <Button Content="Save"
                    Width="90"
                    IsDefault="True"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
