<Window x:Class="GcaEditor.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="500"
        Height="470"
        MinWidth="500"
        MinHeight="470"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="General">
            <StackPanel>
                <CheckBox x:Name="AutoCheckUpdatesCheck"
                          Style="{StaticResource LabeledCheckBoxStyle}"
                          Content="Check for updates automatically at startup"/>

                <CheckBox x:Name="RememberWindowPlacementCheck"
                          Style="{StaticResource LabeledCheckBoxStyle}"
                          Content="Remember window size and position"
                          Margin="0,8,0,0"/>

                <CheckBox x:Name="ConfirmBeforeResetCheck"
                          Style="{StaticResource LabeledCheckBoxStyle}"
                          Content="Confirm before resetting the current workspace"
                          Margin="0,8,0,0"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Editor">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="Maximum undo history"/>

                <ComboBox x:Name="UndoHistoryCombo"
                          Grid.Column="1"
                          Width="100"
                          HorizontalAlignment="Right"
                          IsEditable="False"/>
            </Grid>
        </GroupBox>

        <TextBlock Grid.Row="4"
                   Margin="4,0,0,0"
                   Foreground="{DynamicResource AppMutedTextBrush}"
                   Text="Undo history changes apply on the next app launch."/>

        <GroupBox Grid.Row="6" Header="Viewer">
            <StackPanel>
                <CheckBox x:Name="InvertHorizontalScrollCheck"
                          Style="{StaticResource LabeledCheckBoxStyle}"
                          Content="Invert horizontal trackpad scrolling"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="7" Header="Updates" Margin="0,10,0,0">
            <StackPanel>
                <CheckBox x:Name="IncludePrereleaseCheck"
                          Style="{StaticResource LabeledCheckBoxStyle}"
                          Content="Include prerelease versions in update checks"/>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Cancel"
                    Width="90"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>

            <Button Content="Save"
                    Width="90"
                    IsDefault="True"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
    