<Window x:Class="GcaEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:GcaEditor.UI.Controls"
        Title="GCA Editor"
        Width="1400"
        Height="900">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT -->
        <Grid Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <Button x:Name="ImportBackgroundButton"
                        Content="Import Background (PNG 1280x556)"
                        Click="ImportBackground_Click"
                        Margin="0,0,0,6"/>

                <Button x:Name="OpenGcaButton"
                        Content="Open .gca"
                        Click="OpenGca_Click"
                        Margin="0,0,0,6"
                        IsEnabled="False"/>

                <Button x:Name="SaveGcaButton"
                        Content="Save .gca"
                        Click="SaveGca_Click"
                        Margin="0,0,0,12"
                        IsEnabled="False"/>
            </StackPanel>

            <StackPanel Grid.Row="2">

                <!-- ZONES -->
                <GroupBox Header="Zones" Padding="8" Height="195" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListBox x:Name="ZonesList"
                                 Height="92"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="ZonesList_SelectionChanged"/>

                        <Grid Grid.Row="2" Margin="0,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="2" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Available" FontSize="11" Foreground="Gray" Margin="0,0,0,2"/>
                                    <ComboBox x:Name="AddZoneCombo"
                                              Height="28"
                                              VerticalContentAlignment="Center"
                                              Padding="6,2"
                                              IsEditable="False"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Custom" FontSize="11" Foreground="Gray" Margin="0,0,0,2"/>
                                    <TextBox x:Name="CustomZoneIdBox"
                                             Width="70"
                                             Height="28"
                                             VerticalContentAlignment="Center"
                                             Padding="6,2"
                                             ToolTip="Custom Zone ID (0..65535)"/>
                                </StackPanel>

                                <Button Grid.Column="4" Content="Add" Height="28" Padding="10,4" VerticalAlignment="Bottom" Click="AddZone_Click"/>
                                <Button Grid.Column="6" Content="Delete" Height="28" Padding="10,4" VerticalAlignment="Bottom" Click="DeleteZone_Click"/>
                            </Grid>
                        </Grid>
                    </Grid>
                </GroupBox>

                <!-- AMBIENT IMAGES -->
                <GroupBox Header="Ambient images" Padding="8" Height="320">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Drive side selection -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="Side:" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <RadioButton x:Name="SideLhd" Content="LHD" IsChecked="True" Margin="0,0,10,0" Checked="Side_Checked"/>
                            <RadioButton x:Name="SideRhd" Content="RHD" Checked="Side_Checked"/>
                        </StackPanel>

                        <!-- List of slots -->
                        <ListBox x:Name="AmbientList"
                                 Grid.Row="2"
                                 Height="150"
                                 SelectionChanged="AmbientList_SelectionChanged"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>

                        <TextBlock x:Name="AmbientPlacementHint"
                                   Grid.Row="4"
                                   Margin="0,2,0,0"
                                   Foreground="Gray"
                                   Text="Placement mode: click in the viewer to place the selected ambient image (ESC to cancel)."
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>

                        <!-- Buttons: 2 lines -->
                        <StackPanel Grid.Row="6" Orientation="Vertical">

                            <!-- Line 1: import file / import folder / delete -->
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Import file..."
                                        Click="ImportAmbientFile_Click"
                                        Padding="10,4"
                                        MinWidth="90"
                                        Margin="0,0,6,0"/>

                                <Button Content="Import folder..."
                                        Click="ImportAmbientFolder_Click"
                                        Padding="10,4"
                                        MinWidth="90"
                                        Margin="0,0,6,0"/>

                                <Button Content="Delete"
                                        Click="ClearAmbient_Click"
                                        Padding="10,4"
                                        MinWidth="80"/>
                            </StackPanel>

                            <!-- Line 2: hide/show / place / cancel -->
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button x:Name="ToggleAmbientButton"
                                        Content="Hide/Show"
                                        Click="ToggleAmbientVisibility_Click"
                                        Padding="10,4"
                                        MinWidth="90"
                                        Margin="0,0,6,0"/>

                                <Button x:Name="PlaceAmbientButton"
                                        Content="Place"
                                        Click="PlaceAmbient_Click"
                                        Padding="10,4"
                                        MinWidth="90"
                                        Margin="0,0,6,0"/>

                                <Button x:Name="CancelPlaceAmbientButton"
                                        Content="Cancel"
                                        Click="CancelPlaceAmbient_Click"
                                        Padding="10,4"
                                        MinWidth="90"
                                        IsEnabled="False"/>
                            </StackPanel>

                        </StackPanel>
                    </Grid>
                </GroupBox>

            </StackPanel>
        </Grid>

        <!-- RIGHT -->
        <Grid x:Name="ViewerHost" Grid.Column="1" Margin="12" SizeChanged="ViewerHost_SizeChanged">
            <controls:GcaViewer x:Name="Viewer"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Width="980"
                                Height="480"/>
        </Grid>
    </Grid>
</Window>