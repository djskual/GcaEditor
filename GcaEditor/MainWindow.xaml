<Window x:Class="GcaEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:GcaEditor.UI.Controls"
        Title="GCA Editor"
        Width="1400"
        Height="900">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="10">
            <Button Content="Import Background (PNG 1280x556)" Click="ImportBackground_Click" Margin="0,0,0,6"/>
            <Button Content="Open .gca" Click="OpenGca_Click" Margin="0,0,0,6"/>
            <Button Content="Save .gca" Click="SaveGca_Click" Margin="0,0,0,12"/>
        </StackPanel>

        <!-- Zone droite -->
        <Grid x:Name="ViewerHost" Grid.Column="1" Margin="12" SizeChanged="ViewerHost_SizeChanged">
            <controls:GcaViewer x:Name="Viewer"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Width="980"
                                Height="480"/>
        </Grid>
    </Grid>
</Window>
