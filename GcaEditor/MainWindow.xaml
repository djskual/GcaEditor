<Window x:Class="GcaEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:GcaEditor.UI.Controls"
        Title="GCA Editor"
        Width="1400"
        Height="900">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT -->
        <Grid Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <Button x:Name="ImportBackgroundButton" Content="Import Background (PNG 1280x556)" Click="ImportBackground_Click" Margin="0,0,0,6"/>
                <Button x:Name="OpenGcaButton" Content="Open .gca" Click="OpenGca_Click" Margin="0,0,0,6" IsEnabled="False"/>
                <Button x:Name="SaveGcaButton" Content="Save .gca" Click="SaveGca_Click" Margin="0,0,0,12" IsEnabled="False"/>
            </StackPanel>

            <StackPanel Grid.Row="2">
                <!-- ZONES -->
                <GroupBox Header="Zones" Padding="8" Height="200" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 4 lignes environ + scrollbar -->
                        <ListBox x:Name="ZonesList"
                                 Height="92"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="ZonesList_SelectionChanged"/>

                        <Grid Grid.Row="2" Margin="0,4,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Labels -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Available" FontSize="11" Foreground="Gray"/>
                                <TextBlock Grid.Column="2" Text="Custom" FontSize="11" Foreground="Gray"/>
                            </Grid>

                            <!-- Inputs + buttons -->
                            <Grid Grid.Row="1" Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox x:Name="AddZoneCombo" Grid.Column="0" MinWidth="120" IsEditable="False"/>

                                <TextBox x:Name="CustomZoneIdBox"
                                         Grid.Column="2"
                                         Width="64"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Custom Zone ID (0..65535)"
                                         Text=""/>

                                <Button Grid.Column="4" Content="Add" Padding="10,4" Click="AddZone_Click"/>
                                <Button Grid.Column="6" Content="Delete" Padding="10,4" Click="DeleteZone_Click"/>
                            </Grid>
                        </Grid>
                    </Grid>
                </GroupBox>

                <!-- AMBIENT IMAGES -->
                <GroupBox Header="Ambient images" Padding="8" Height="320">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Drive side selection -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="Side:" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <RadioButton x:Name="SideLhd" Content="LHD" IsChecked="True" Margin="0,0,10,0" Checked="Side_Checked"/>
                            <RadioButton x:Name="SideRhd" Content="RHD" Checked="Side_Checked"/>
                        </StackPanel>

                        <!-- List of slots -->
                        <ListBox x:Name="AmbientList"
                                 Grid.Row="2"
                                 Height="150"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>

                        <!-- Buttons -->
                        <Grid Grid.Row="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Content="Import file..." Click="ImportAmbientFile_Click" Padding="10,4"/>
                            <Button Grid.Column="2" Content="Import folder..." Click="ImportAmbientFolder_Click" Padding="10,4"/>
                            <Button Grid.Column="4" Content="Clear" Click="ClearAmbient_Click" Padding="10,4"/>
                        </Grid>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </Grid>

        <!-- RIGHT -->
        <Grid x:Name="ViewerHost" Grid.Column="1" Margin="12" SizeChanged="ViewerHost_SizeChanged">
            <controls:GcaViewer x:Name="Viewer"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Width="980"
                                Height="480"/>
        </Grid>
    </Grid>
</Window>
