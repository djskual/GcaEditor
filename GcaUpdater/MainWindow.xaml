<Window x:Class="GcaUpdater.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Updating GcaEditor"
        Height="220"
        Width="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#111827"
        Foreground="White">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="GcaEditor Update"
                   FontSize="22"
                   FontWeight="SemiBold" />

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="1"
                   Margin="0,16,0,0"
                   Text="Preparing update..."
                   FontSize="14"
                   TextWrapping="Wrap" />

        <ProgressBar x:Name="MainProgressBar"
                     Grid.Row="2"
                     Margin="0,18,0,0"
                     Height="18"
                     Minimum="0"
                     Maximum="100"
                     Value="0" />

        <TextBox x:Name="LogTextBox"
                 Grid.Row="3"
                 Margin="0,16,0,0"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"
                 Background="#0B1220"
                 BorderBrush="#374151"
                 Foreground="#D1D5DB" />

        <StackPanel Grid.Row="4"
                    Margin="0,16,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="CloseButton"
                    Width="110"
                    Height="30"
                    Content="Close"
                    IsEnabled="False"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
